{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vitest/globals"],
    "useDefineForClassFields": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
