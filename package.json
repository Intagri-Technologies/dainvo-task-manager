{
  "name": "dainvo-task-manager",
  "version": "1.0.2",
  "description": "Community plugin for syncing vault tasks with Dainvo.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "dainvo",
    "tasks"
  ],
  "author": "Intagri Technologies",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "esbuild": "^0.27.1",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "obsidian-daily-notes-interface": "^0.9.5"
  }
}
