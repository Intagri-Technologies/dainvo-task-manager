{
  "name": "dainvo-task-manager",
  "version": "1.1.5",
  "description": "Sync Obsidian task projections directly with Dainvo mobile or through Dainvo desktop.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "dainvo",
    "tasks"
  ],
  "author": "Intagri Technologies",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@types/node": "^25.6.2",
    "@typescript-eslint/parser": "8.64.0",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "obsidian-daily-notes-interface": "^0.9.5"
  }
}
